<main class="container mx-auto px-4 sm:px-6 py-8">
  <div class="max-w-7xl mx-auto">
    <!-- Cart Header -->
    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-8 pb-6 border-b border-[#F5D5C8]/30">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-serif text-[#8B6F5C]">Shopping Cart</h1>
      {% if cart.item_count > 0 %}
        <span class="inline-block text-sm px-4 py-2 bg-[#F8C8DC]/20 text-[#8B6F5C] rounded-full font-semibold w-fit">
          {{ cart.item_count }} item{{ cart.item_count | pluralize: '', 's' }}
        </span>
      {% endif %}
    </div>

    {% if cart.item_count > 0 %}
      <form action="/cart/update" method="post" id="cart-form">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
          <!-- Cart Items -->
          <div class="lg:col-span-2 space-y-6">
            {% for item in cart.items %}
              <div class="flex gap-4 sm:gap-6 pb-6 border-b border-[#F5D5C8]/30 last:border-0" data-line="{{ forloop.index }}">
                <!-- Product Image -->
                <a href="{{ item.url }}" class="flex-shrink-0">
                  <img 
                    src="{{ item.image | image_url: width: 240 }}" 
                    alt="{{ item.title }}" 
                    class="w-20 h-20 sm:w-24 sm:h-24 object-cover rounded-lg border border-[#F5D5C8]/30"
                  >
                </a>

                <!-- Product Details -->
                <div class="flex-1 min-w-0">
                  <a href="{{ item.url }}" class="text-lg sm:text-xl font-serif text-[#8B6F5C] hover:text-[#8B6F5C]/80 transition-colors block mb-2">
                    {{ item.product.title }}
                  </a>
                  
                  {% if item.variant.title != 'Default Title' %}
                    <p class="text-sm text-[#A08577] mb-2">{{ item.variant.title }}</p>
                  {% endif %}
                  
                  {% if item.properties.size > 0 %}
                    <div class="text-xs text-[#A08577] mb-2 space-y-1">
                      {% for property in item.properties %}
                        <p>{{ property.first }}: {{ property.last }}</p>
                      {% endfor %}
                    </div>
                  {% endif %}

                  <p class="text-base sm:text-lg font-semibold text-[#8B6F5C]" data-price="{{ item.price }}">
                    {{ item.price | money }}
                  </p>
                </div>

                <!-- Quantity & Remove -->
                <div class="flex flex-col items-end justify-between gap-4">
                  <!-- Quantity Controls -->
                  <div class="flex items-center gap-2 border border-[#F5D5C8]/30 rounded-lg p-1">
                    <button 
                      type="button" 
                      class="w-8 h-8 flex items-center justify-center text-[#8B6F5C] hover:bg-[#F8C8DC]/10 rounded transition-colors disabled:opacity-50 disabled:cursor-not-allowed" 
                      data-action="decrease" 
                      data-line="{{ forloop.index }}" 
                      {% if item.quantity <= 1 %}disabled{% endif %}
                      title="Decrease quantity"
                    >
                      −
                    </button>
                    <input 
                      type="number" 
                      class="w-12 text-center text-sm bg-transparent text-[#8B6F5C] border-0 focus:outline-none" 
                      name="updates[{{ forloop.index }}]" 
                      value="{{ item.quantity }}" 
                      min="1" 
                      max="{{ item.variant.inventory_quantity | default: 999 }}" 
                      data-line="{{ forloop.index }}"
                    >
                    <button 
                      type="button" 
                      class="w-8 h-8 flex items-center justify-center text-[#8B6F5C] hover:bg-[#F8C8DC]/10 rounded transition-colors" 
                      data-action="increase" 
                      data-line="{{ forloop.index }}"
                      title="Increase quantity"
                    >
                      +
                    </button>
                  </div>

                  <!-- Line Total & Remove -->
                  <div class="text-right">
                    <p class="text-sm text-[#A08577] mb-2" data-line="{{ forloop.index }}">
                      {{ item.line_price | money }}
                    </p>
                    <button 
                      type="button" 
                      class="text-xs text-[#F8C8DC] hover:text-[#8B6F5C] transition-colors underline" 
                      data-line="{{ forloop.index }}"
                    >
                      Remove
                    </button>
                  </div>
                </div>
              </div>
            {% endfor %}

            <!-- Add Note Section -->
            <div class="bg-[#F8F9FA] border border-[#F5D5C8]/20 rounded-lg p-6">
              <h3 class="text-lg font-semibold text-[#8B6F5C] mb-4">Add a note to your order (optional)</h3>
              <textarea 
                id="cart-note" 
                name="note" 
                placeholder="Add special instructions, delivery notes, or any other information..."
                class="w-full min-h-24 px-4 py-3 border border-[#F5D5C8]/30 rounded-lg text-[#8B6F5C] placeholder-[#A08577] focus:outline-none focus:ring-2 focus:ring-[#F8C8DC] focus:border-transparent resize-vertical"
              >{{ cart.note }}</textarea>
            </div>
          </div>

          <!-- Cart Summary Sidebar -->
          <div class="lg:col-span-1">
            <div class="bg-[#F8F9FA] border border-[#F5D5C8]/20 rounded-lg p-6 sticky top-20">
              <!-- Order Summary -->
              <div class="mb-6">
                <h3 class="text-xl font-semibold text-[#8B6F5C] mb-4">Order Summary</h3>
                
                <div class="space-y-3 mb-4 pb-4 border-b border-[#F5D5C8]/30">
                  <div class="flex justify-between text-sm text-[#A08577]">
                    <span>Subtotal ({{ cart.item_count }} item{{ cart.item_count | pluralize: '', 's' }})</span>
                    <span data-cart-subtotal data-initial="{{ cart.total_price }}">{{ cart.total_price | money }}</span>
                  </div>
                  
                  {% if cart.total_discounts > 0 %}
                    <div class="flex justify-between text-sm text-[#F8C8DC] font-semibold">
                      <span>Discount</span>
                      <span>-{{ cart.total_discounts | money }}</span>
                    </div>
                  {% endif %}
                </div>

                <div class="flex justify-between text-lg font-serif text-[#8B6F5C] mb-6">
                  <span>Total</span>
                  <span data-cart-total data-initial="{{ cart.total_price }}">{{ cart.total_price | money }}</span>
                </div>
              </div>

              <!-- Checkout Button -->
              <button 
                type="submit" 
                class="w-full bg-[#F8C8DC] hover:bg-[#F5B5CE] text-white font-semibold py-3 px-4 rounded-full transition-colors mb-3"
                formaction="/checkout"
              >
                Proceed to Checkout
              </button>

              <!-- Cart Actions -->
              <div class="space-y-2">
                <button 
                  type="submit" 
                  class="w-full border border-[#F5D5C8]/30 bg-white text-[#8B6F5C] font-semibold py-2 px-4 rounded-lg hover:bg-[#F8F9FA] transition-colors"
                >
                  Update Cart
                </button>
                <button 
                  type="submit" 
                  class="w-full border-2 border-red-400 bg-white text-red-500 font-semibold py-2 px-4 rounded-lg hover:bg-red-50 transition-colors"
                  formaction="/cart/clear"
                >
                  Clear Cart
                </button>
              </div>
            </div>
          </div>
        </div>
      </form>
    {% else %}
      <div class="text-center py-16 sm:py-24">
        <svg class="w-16 h-16 sm:w-20 sm:h-20 text-[#F5D5C8] mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
        </svg>
        <h2 class="text-2xl sm:text-3xl font-serif text-[#8B6F5C] mb-3">Your cart is empty</h2>
        <p class="text-[#A08577] text-base sm:text-lg mb-8">Add some products to get started!</p>
        <a href="/" class="inline-block bg-[#F8C8DC] hover:bg-[#F5B5CE] text-white font-semibold py-3 px-8 rounded-full transition-colors">
          Continue Shopping
        </a>
      </div>
    {% endif %}
  </div>
</main>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    function updateTotals() {
      let total = 0;
      let itemCount = 0;

      document.querySelectorAll('[data-line]').forEach(item => {
        const quantityInput = item.querySelector('.quantity-input');
        const priceElement = item.querySelector('[data-price]');
        const subtotalElement = item.querySelector('[data-line]');

        if (quantityInput && priceElement && subtotalElement && quantityInput.value) {
          const quantity = parseInt(quantityInput.value) || 0;
          const price = parseInt(priceElement.dataset.price) || 0;

          if (quantity > 0 && price > 0) {
            itemCount += quantity;
            const lineTotal = (price * quantity) / 100;
            subtotalElement.textContent = '$' + lineTotal.toFixed(2);
            total += lineTotal;
          } else {
            subtotalElement.textContent = '$0.00';
          }
        }
      });

      const subtotalElement = document.querySelector('[data-cart-subtotal]');
      const totalElement = document.querySelector('[data-cart-total]');

      if (subtotalElement) subtotalElement.textContent = '$' + total.toFixed(2);
      if (totalElement) totalElement.textContent = '$' + total.toFixed(2);
    }

    // Quantity buttons
    document.querySelectorAll('.quantity-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        const input = this.parentElement.querySelector('.quantity-input');
        let quantity = parseInt(input.value) || 0;

        if (this.dataset.action === 'increase') {
          quantity++;
        } else if (this.dataset.action === 'decrease' && quantity > 1) {
          quantity--;
        }

        input.value = quantity;
        this.parentElement.querySelector('[data-action="decrease"]').disabled = quantity <= 1;
        updateTotals();
      });
    });

    // Remove item buttons
    document.querySelectorAll('[data-line] button[data-line]:not([data-action])').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        this.closest('[data-line]').remove();
        updateTotals();
      });
    });

    updateTotals();
  });
</script>
