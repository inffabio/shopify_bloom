<header class="store-header">
    <div class="store-header__container">
        <div class="store-header__top">
            <div class="store-header__brand">
                <a href="{{ shop.url }}" class="store-header__brand-link">
                    {% if shop.brand.logo %}
                        <img src="{{ brand.logo | image_url: width: 250 }}" alt="{{ shop.name }}" class="store-header__logo" />
                    {% else %}
                        <span class="store-header__logo-text">{{ shop.name }}</span>
                    {% endif %}
                </a>
            </div>

            <nav class="store-header__nav" aria-label="Primary navigation">
                {% for link in linklists.main-menu.links %}
                <a href="{{ link.url }}" class="store-header__nav-link">{{ link.title }}</a>
                {% endfor %}
            </nav>

            <div class="store-header__actions">
                <a href="/account" class="store-header__action-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="currentColor"/>
                </svg>
                </a>
            <a href="/cart" class="store-header__action-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M17 18c-1.11 0-2 .89-2 2a2 2 0 0 0 2 2 2 2 0 0 0 2-2c0-1.11-.89-2-2-2M1 2v2h2l3.6 7.59L5.24 14.04c-.15.28-.24.61-.24.96a2 2 0 0 0 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25 0-.05.01-.09.03-.12L8.1 13h7.45c.75 0 1.41-.42 1.75-1.03l3.58-6.49c.07-.16.12-.33.12-.51a1 1 0 0 0-1-1H5.21l-.94-2M7 18c-1.11 0-2 .89-2 2a2 2 0 0 0 2 2 2 2 0 0 0 2-2c0-1.11-.89-2-2-2z" fill="currentColor"/>
            </svg>
            </a>
            </div>
        </div>

        <div class="store-header__search-bar">
            <form action="/search" method="get" class="store-header__search-form">
                <label for="header-search" class="visually-hidden">Search products</label>
                <input
                    id="header-search"
                    type="search"
                    name="q"
                    placeholder="Search products, brands, styles"
                    class="store-header__search-input"
                />
                <button type="submit" class="store-header__search-button">Search</button>
            </form>
        </div>
    </div>
</header>

<style>
.store-header {
    width: 100%;
    border-bottom: 1px solid #ececec;
    background: #ffffff;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.store-header__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
}

.store-header__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1rem 0;
    flex-wrap: wrap;
}

.store-header__brand {
    flex: 1 1 auto;
    min-width: 180px;
}

.store-header__brand-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
}

.store-header__logo {
    max-height: 48px;
    width: auto;
    display: block;
}

.store-header__logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    color: #111;
}

.store-header__nav {
    display: flex;
    gap: 1rem;
    flex: 2 1 auto;
    flex-wrap: wrap;
    justify-content: center;
}

.store-header__nav-link {
    color: #333;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
}

.store-header__nav-link:hover {
    color: #000;
}

.store-header__actions {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex: 1 1 auto;
    justify-content: flex-end;
    min-width: 160px;
}

.store-header__action-link {
    color: #333;
    text-decoration: none;
    font-weight: 500;
}

.store-header__action-link:hover {
    color: #000;
}

.store-header__search-bar {
    padding: 0.75rem 0 1.25rem;
}

.store-header__search-form {
    display: flex;
    gap: 0.5rem;
    max-width: 760px;
    margin: 0 auto;
}

.store-header__search-input {
    flex: 1;
    min-width: 0;
    padding: 0.85rem 1rem;
    border: 1px solid #dcdcdc;
    border-radius: 999px;
    font-size: 0.95rem;
    outline: none;
}

.store-header__search-input:focus {
    border-color: #888;
}

.store-header__search-button {
    padding: 0.85rem 1.25rem;
    border: none;
    border-radius: 999px;
    background: #111;
    color: #fff;
    cursor: pointer;
    font-weight: 600;
    transition: background 0.2s ease;
}

.store-header__search-button:hover {
    background: #333;
}

.visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    border: 0;
}
</style>