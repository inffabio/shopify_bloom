
{% stylesheet %}
    /* Hero styling handled via Tailwind utilities */
{% endstylesheet %}

<section class="relative z-10 py-8 sm:py-8 md:py-12 px-4 sm:px-6">
    <div class="container mx-auto max-w-4xl text-center flex flex-col items-center">
        <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl font-serif text-[#8B6F5C] mb-4 sm:mb-6 text-balance">
            {{ section.settings.heading }}
        </h2>
        <p class="text-base sm:text-lg text-[#A08577] mb-6 sm:mb-8 max-w-2xl mx-auto leading-relaxed px-4">
            {{ section.settings.description }}
        </p>
        <a href="{{ section.settings.button_link }}" class="inline-block rounded-full bg-[#F8C8DC] hover:bg-[#F5B5CE] text-white px-8 py-3 text-2xlshadow-lg transition-colors">
            {{ section.settings.button_text }}
        </a>
    </div>
</section>

{% schema %}
{
    "name": "Hero Section",
    "settings": [
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Custom Mugs & Personalized Drinkware"
        },
        {
            "type": "textarea",
            "id": "description",
            "label": "Description",
            "default": "Transform your daily moments with beautifully personalized mugs and tumblers. From custom designs to elegant sets, we create drinkware that reflects your unique style and brings joy to every sip."
        },
        {
            "type": "text",
            "id": "button_text",
            "label": "Button Text",
            "default": "Shop Now"
        },
        {
            "type": "text",
            "id": "button_link",
            "label": "Button Link",
            "default": "#products"
        }
    ],
    "presets": [
        {
            "name": "Hero Section",
            "category": "General"
        }
    ]
}
{% endschema %}
      