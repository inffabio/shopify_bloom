<div class="relative bg-gradient-to-r from-blossom-50 to-blossom-100" x-data="{ mobileMenuOpen: false }">
    <div class="mx-auto px-4 sm:px-6">
        <div class="flex justify-between items-center py-6 md:justify-start md:space-x-10">
            <!-- STORE NAME / STORE LOGO -->
            <div class="flex justify-start lg:flex-1 truncate">
                <h1 class="text-xl font-bold truncate">{{ shop.name }}</h1>
            </div>

            <div class="-mr-2 -my-2 ml-3 md:hidden">
                <!-- Hamburger Menu (Mobile Only) -->
                <button x-on:click="mobileMenuOpen = true" type="button"
                    class=" p-2 inline-flex items-center justify-center focus:outline-none">
                    {% render 'icon-hamburguer-menu' %}
                </button>
            </div>



            <!-- NAVIGATION MENU -->
            <nav x-data="{ open: false }" class="hidden md:flex space-x-10">
                {% for link in linklists.main-menu.links %}
                {% if link.links != blank %}
                <div class="relative">

                    <button x-on:click="open = !open" type="button"
                        class="inline-flex items-center text-base  text-[#8B6F5C] hover:text-[#6B5F4C] transition-colors no-underline font-bold tracking-wide whitespace-nowrap uppercase font-sans">
                        {{ link.title }}
                        {% render 'icon-dropdown' %}
                    </button>

                    <div x-show="open" @click.away="open = false"
                        class="absolute z-10 -ml-5 mt-6 transform px-2 w-screen max-w-md sm:px-0 lg:ml-0 lg:left-1/2 lg:-translate-x-1/2">
                        <div class="shadow-lg border ring-black ring-opacity-5 overflow-hidden rounded-lg">
                            <div class="relative grid gap-6 bg-white px-5 py-6 sm:gap-8 sm:p-8">
                                {% for childLink in link.links %}
                                    <!-- CREATE THE SUBLINK -->
                                    <a href="{{ childLink.url }}" class="-m-2 p-2 text-[#8B6F5C] hover:text-[#6B5F4C] transition-colors no-underline font-bold text-base tracking-wide whitespace-nowrap uppercase font-sans">
                                        <div class="ml-4">
                                            <p class="text-base font-medium">
                                                {{ childLink.title }}
                                            </p>
                                        </div>
                                    </a> 
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>

                {% else %}
                <div class="relative">
                    <a href="{{ link.url }}" class="text-base text-[#8B6F5C] hover:text-[#6B5F4C] transition-colors no-underline font-bold tracking-wide whitespace-nowrap uppercase font-sans">
                        {{ link.title }}
                    </a>
                </div>

                {% endif %}
                {% endfor %}
            </nav>

            <div class="hidden md:flex items-center justify-end md:flex-1 space-x-5">
                <a href="/cart" class="text-base text-[#8B6F5C] hover:text-[#6B5F4C] transition-colors no-underline font-bold tracking-wide whitespace-nowrap uppercase font-sans">
                    {% render 'icon-shopping-bag' %}
                </a>

                <a class="text-base text-[#8B6F5C] hover:text-[#6B5F4C] transition-colors no-underline font-bold tracking-wide whitespace-nowrap uppercase font-sans">Login</a>
                <a class="text-base text-[#8B6F5C] hover:text-[#6B5F4C] transition-colors no-underline font-bold tracking-wide whitespace-nowrap uppercase font-sans">Register</a>
            </div>
        </div>
    </div>

    <!-- MOBILE MENU CONTAINER -->
    <div x-show="mobileMenuOpen" class="absolute z-10 top-0 inset-x-0 p-2 transform origin-top-left md:hidden">
        <div class="shadow-lg rounded-lg ring-1 ring-black ring-opacity-5 bg-white w-full">
            <div class="p-5 divide-y-2 divide-gray-50">

                <!-- MOBILE MENU HEADER TITLE PLUS CLOSE BUTTON -->
                <div class="flex items-center justify-between pb-3">
                    <div>
                        <h1 class="text-lg text-[#8B6F5C]">{{ shop.name }}</h1>
                    </div>
                    <div class="-mr-2">
                        <button x-on:click="mobileMenuOpen = false" type="button"
                            class="bg-white rounded-md  text-[#8B6F5C]  font-bold">
                            {% render 'icon-close' %}
                        </button>
                    </div>
                </div>

                <!-- NAVIGATION LINKS FOR MOBILE MENU -->
                <div class="pt-3">
                    <nav class="grid gap-y-7">
                        {% for link in linklists.main-menu.links %}
                            {% assign link_handle = link.handle | replace: '-', '_' %}
                        {% if link.links != blank %}
                            <div x-data="{ {{link_handle}}: false }" class="relative">
                                <button x-on:click="{{link_handle}} = !{{link_handle}}" type="button"
                                    class="text-base text-[#8B6F5C] hover:text-[#6B5F4C] transition-colors no-underline font-bold tracking-wide whitespace-nowrap uppercase font-sans flex items-center justify-between w-full">
                                    <div>{{ link.title }}</div>
                                    {% render 'icon-dropdown' %}
                                </button>

                                <div x-show="{{link_handle}}" class="grid gap-y-7 py-3">
                                    {% for childlink in link.links %}
                                        <a href="{{ childlink.url }}" class="p-3 hover:bg-gray-200 transition-colors no-underline font-bold tracking-wide whitespace-nowrap uppercase font-sans">
                                            <span class="ml-3  text-base font-medium text-[#8B6F5C]">{{ childlink.title }}</span>
                                        </a>
                                    {% endfor %}
                                </div>
                            </div>
                        {% else %}
                        <a href="#"
                            class="-m-3 p-3 flex items-center rounded-md text-[#8B6F5C] hover:text-[#6B5F4C] hover:bg-gray-200 transition-colors no-underline font-bold tracking-wide whitespace-nowrap uppercase font-sans">
                            {{ link.title }}
                        </a>
                        {% endif %}
                        {% endfor %}
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>